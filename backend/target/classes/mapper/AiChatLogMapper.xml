<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.project.mapper.AiChatLogMapper">

    <!--
      自定义结果映射 — 仅在需要扩展 MyBatis-Plus 自动映射时使用
      （如关联查询、集合映射、自定义类型处理器）。
      默认情况下 MyBatis-Plus 会将下划线列名自动映射为驼峰字段。
    -->
    <resultMap id="BaseResultMap" type="com.ai.project.entity.AiChatLog">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="user_message" property="userMessage"/>
        <result column="ai_reply" property="aiReply"/>
        <result column="model" property="model"/>
        <result column="prompt_tokens" property="promptTokens"/>
        <result column="completion_tokens" property="completionTokens"/>
        <result column="total_tokens" property="totalTokens"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="deleted"/>
    </resultMap>

    <!--
      自定义查询示例 — 获取某会话最新的 N 条记录
      演示如何与 MyBatis-Plus 自动方法配合使用手写 XML
    -->
    <select id="selectLatestBySession" resultMap="BaseResultMap">
        SELECT * FROM ai_chat_log
        WHERE session_id = #{sessionId}
          AND is_deleted = 0
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

</mapper>
